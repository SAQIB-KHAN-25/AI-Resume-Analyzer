# Backend
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# MongoDB Atlas
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=ai_resume_analyzer
MONGODB_REQUIRED=true
MONGODB_MAX_POOL_SIZE=20

# JWT (use 32+ chars in production)
JWT_SECRET_KEY=replace-with-a-strong-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120

# CORS / hosts
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?\$
TRUSTED_HOSTS=localhost,127.0.0.1

# Uploads
MAX_UPLOAD_SIZE_BYTES=5242880

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ─── Email (for forgot-password OTP delivery) ─────────────────────────────
# We use Gmail SMTP with an App Password. Steps:
#   1. Enable 2-Step Verification on your Google account.
#   2. Generate an App Password: https://myaccount.google.com/apppasswords
#   3. Paste the 16-character password into SMTP_PASS (no spaces).
# If SMTP_USER/PASS are blank, OTP flow falls back to logging the code to the
# backend console — useful for local dev without email configured.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=ResuMatch AI <your.email@gmail.com>
SMTP_USE_SSL=false

# ─── OTP behavior (safe defaults shown) ───────────────────────────────────
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
RESET_TOKEN_TTL_MINUTES=10

# ─── Rate limiting ────────────────────────────────────────────────────────
# Set to 'true' to disable all rate limits (load-testing / CI).
RATE_LIMIT_DISABLED=false
# Trust X-Forwarded-For / X-Real-IP. Enable ONLY when behind a trusted proxy.
TRUST_PROXY_HEADERS=false
